{
  "federated": {
    "n_clients": 3,
    "num_rounds": 15,
    "local_epochs": 1,
    "batch_size": 32,
    "learning_rate": 0.01,
    "dirichlet_alpha": 0.5,
    "fraction_fit": 1.0,
    "fraction_evaluate": 1.0,
    "min_fit_clients": 2,
    "min_evaluate_clients": 2,
    "min_available_clients": 2
  },
  "strategy": {
    "name": "fedavg",
    "fedprox_mu": 0.1
  },
  "model": {
    "type": "logistic",
    "logistic": {
      "C": 1.0,
      "penalty": "l2",
      "solver": "lbfgs",
      "max_iter": 1000,
      "warm_start": true
    }
  },
  "privacy": {
    "enabled": false,
    "epsilon": 1.0,
    "delta": 1e-5,
    "clip_norm": 1.0
  },
  "server": {
    "address": "127.0.0.1:8080"
  },
  "reproducibility": {
    "random_state": 42
  },
  "data": {
    "test_size": 0.2,
    "dataset_filename": "diabetes_binary.csv"
  },
  "success_criteria": {
    "convergence_rounds": 20,
    "accuracy_loss_tolerance": 0.05,
    "max_communication_mb": 500
  }
}
